# Syteline IDO REST API - Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
SYTELINE_BASE_URL=https://YOUR-SYTELINE-HOST/IDORequestService/ido
DEFAULT_SITE=YourSiteConfigName

# Agent User — introspection only (meta-IDO read/execute access)
# This user discovers IDO structure but cannot access real business data.
SYTELINE_AGENT_USERNAME=
SYTELINE_AGENT_PASSWORD=

# Automation User — optional, for testing/executing API calls
# Grant task-specific IDO permissions to this user as needed.
# SYTELINE_AUTOMATION_USERNAME=
# SYTELINE_AUTOMATION_PASSWORD=

# Notification Settings
NOTIFICATION_EMAIL=
